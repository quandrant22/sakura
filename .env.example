# ──────────────────────────────────────────────────────────────
# Sakura VPS — пример переменных окружения
# Скопируй в .env и заполни реальными значениями.
# НИКОГДА не коммить .env в репозиторий.
# ──────────────────────────────────────────────────────────────

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here
MASTER_ID=your_telegram_user_id
HIMARI_ID=0
GROUP_CHAT_ID=0

# Gemini API (добавляй ключи последовательно: GEMINI_KEY_1, GEMINI_KEY_2, ...)
# ⚠️  КЛЮЧИ ИЗ АРХИВА (AIzaSy...) СКОМПРОМЕТИРОВАНЫ — перевыпусти их на
#     https://aistudio.google.com/ → API Keys → Delete + Create new
GEMINI_KEY_1=your_gemini_key_here
GEMINI_KEY_2=
GEMINI_KEY_3=

# WebSocket аутентификация
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
WS_SECRET=replace_with_output_of_generate_token_py

# Google Calendar OAuth (если используется)
# credentials.json и token.json хранятся ТОЛЬКО локально, не в репо
GOOGLE_CREDENTIALS_PATH=memory/credentials.json
GOOGLE_TOKEN_PATH=memory/token.json

# Unsplash (опционально)
UNSPLASH_KEY=
