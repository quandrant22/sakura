# ──────────────────────────────────────────────────────────────
# Sakura Агент (ПК / ноутбук) — пример переменных окружения
# Скопируй в .env и заполни реальными значениями.
# ──────────────────────────────────────────────────────────────

# Подключение к VPS
# wss:// — после настройки Caddy/nginx с TLS
# ws://  — только для локальной разработки без TLS
VPS_WS_URL=wss://your.domain.com/ws

# Идентификатор этого устройства (laptop / pc / phone)
DEVICE_ID=laptop

# Токен авторизации — должен совпадать с WS_SECRET на VPS
# Генерация: python generate_token.py
WS_TOKEN=replace_with_same_value_as_vps_WS_SECRET

# Yandex SpeechKit (TTS)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
